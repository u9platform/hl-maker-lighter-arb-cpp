FROM ubuntu:24.04 AS builder
RUN apt-get update && apt-get install -y \
    g++ cmake make libcurl4-openssl-dev libsecp256k1-dev \
    libboost-all-dev libssl-dev \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY . .
RUN mkdir -p build && cd build && cmake .. -DCMAKE_BUILD_TYPE=Release && make -j1 arb_live
